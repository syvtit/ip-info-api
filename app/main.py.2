from fastapi import FastAPI, Request
from fastapi.responses import PlainTextResponse
import ipaddress

app = FastAPI(title="ifconfig.7it.vn")


def _first_ip_from_xff(xff: str | None) -> str | None:
    if not xff:
        return None
    # X-Forwarded-For: client, proxy1, proxy2...
    return xff.split(",")[0].strip() or None


def get_client_ip(request: Request) -> str:
    """
    Priority:
    1) Cloudflare: CF-Connecting-IP (real client IP, can be IPv6)
    2) Standard proxy: X-Forwarded-For (first hop)
    3) Direct: request.client.host
    """
    cf_ip = request.headers.get("cf-connecting-ip")
    if cf_ip:
        return cf_ip.strip()

    xff_ip = _first_ip_from_xff(request.headers.get("x-forwarded-for"))
    if xff_ip:
        return xff_ip

    return request.client.host


def classify_ip(ip: str) -> tuple[str, str]:
    """
    Returns (ip_type, network_scope)
    ip_type: IPv4 | IPv6 | Unknown
    network_scope: Public | Private | Unknown
    """
    try:
        ip_obj = ipaddress.ip_address(ip)
        ip_type = "IPv4" if ip_obj.version == 4 else "IPv6"
        network = "Private" if ip_obj.is_private else "Public"
        return ip_type, network
    except ValueError:
        return "Unknown", "Unknown"


@app.get("/raw", response_class=PlainTextResponse)
def raw(request: Request):
    """Return only the client IP (best for scripts / JS)."""
    return get_client_ip(request)


@app.get("/", response_class=PlainTextResponse)
def info(request: Request):
    """Human-friendly output."""
    ip = get_client_ip(request)
    ip_type, network = classify_ip(ip)
    ua = request.headers.get("user-agent", "unknown")

    # Optional: show proxy chain in a friendly way (not Python list)
    xff = request.headers.get("x-forwarded-for")
    chain = [s.strip() for s in xff.split(",")] if xff else [ip]

    lines = [
        f"IP: {ip}",
        f"Type: {ip_type}",
        f"Network: {network}",
        "",
        "Proxy:",
        *[f"  - {hop}" for hop in chain],
        "",
        "User-Agent:",
        f"  {ua}",
    ]
    return "\n".join(lines)
